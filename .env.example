# ============================================================
#  AgriGuard — Environment Variables Template
#  Copy this file to .env and fill in your actual values.
#  NEVER commit the .env file to version control.
# ============================================================

# ─── Flask Core ─────────────────────────────────────────────
FLASK_APP=app.py
FLASK_ENV=development
SECRET_KEY=replace_with_a_secure_random_key_in_production

# ─── Admin Account ──────────────────────────────────────────
ADMIN_EMAIL=admin@agriguard.com
ADMIN_PASSWORD=replace_with_a_secure_admin_password

# ─── LOCAL Development (SQLite) ─────────────────────────────
# Used only when running locally without Supabase
DATABASE_PATH=agriguard.db
UPLOAD_FOLDER=static/uploads

# ─── Supabase (Production Database) ─────────────────────────
# Get these from: https://supabase.com → Your Project → Settings → Database / API
SUPABASE_URL=https://xxxxxxxxxxxxxxxxxxxx.supabase.co
SUPABASE_KEY=your-supabase-anon-public-key-here
DATABASE_URL=postgresql://postgres:[YOUR-DB-PASSWORD]@db.xxxxxxxxxxxxxxxxxxxx.supabase.co:5432/postgres

# ─── Vercel (Backend Deployment) ────────────────────────────
# Set these as Environment Variables inside your Vercel project dashboard
# https://vercel.com → Project → Settings → Environment Variables
# (No local values needed — for documentation reference only)

# ─── Netlify (Frontend Deployment) ──────────────────────────
# The URL of your deployed Vercel backend — used by the frontend
# Set this inside Netlify: Site Settings → Environment Variables
VITE_API_URL=https://your-vercel-project.vercel.app

# ─── CORS ───────────────────────────────────────────────────
# Your Netlify frontend URL — added to Flask CORS whitelist
FRONTEND_URL=https://your-site-name.netlify.app
